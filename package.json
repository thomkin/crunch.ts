{
  "name": "crunch.ts",
  "version": "1.0.0",
  "description": "",
  "bin": {
    "crunchy": "./bin/crunchy.mts"
  },
  "main": "./src/types/service.ts",
  "types": "./src/types/service.ts",
  "files": [
    "build/tsc",
    "src",
    "scripts",
    "README.md"
  ],
  "exports": {
    ".": "./build/tsc/src/handler.js",
    "./router/rpc": "./build/tsc/src/router/rpc.js",
    "./router/http": "./build/tsc/src/router/http.js",
    "./auth": "./build/tsc/src/auth/jwt.js",
    "./types": "./build/tsc/src/types/service.js",
    "./scripts/buildRegistry": "./build/tsc/scripts/buildRegistry.js",
    "./scripts/buildClient": "./build/tsc/scripts/buildClient.js"
  },
  "scripts": {
    "build": "cross-env CRUNCH_CFG=./crunchy.json tsx ./bin/crunchy.mts build",
    "client": "cross-env CRUNCH_CFG=./crunchy.json tsx ./bin/crunchy.mts build:client",
    "test": "cross-env CRUNCH_CFG=./crunchy.json pnpm build && pnpm client && vitest run",
    "prepare": "ts-patch install"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "ts-node": {
    "esm": true,
    "compilerOptions": {
      "module": "CommonJS"
    }
  },
  "devDependencies": {
    "@bunny.net/edgescript-sdk": "^0.12.1",
    "@types/node": "^25.5.0",
    "@typia/unplugin": "^12.0.1",
    "cross-env": "^10.1.0",
    "esbuild": "^0.27.4",
    "ts-node": "^10.9.2",
    "ts-patch": "^3.3.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typia": "^11.0.3",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "ky": "^1.14.3"
  }
}